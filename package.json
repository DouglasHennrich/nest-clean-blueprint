{
  "name": "nest-clean-blueprint",
  "version": "0.1.0",
  "description": "Bootstrap project for NestJS with Clean / Layered Architecture, Result pattern, Zod validation, and shared providers (mail/encrypt/upload). Consumable via MCP.",
  "license": "MIT",
  "private": false,
  "scripts": {
    "check": "pnpm tsc --noEmit",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,tests}/**/*.ts\" --fix",
    "test": "jest",
    "test:unit": "jest --testRegex=\".*\\.spec\\.ts$\"",
    "test:e2e": "jest --testRegex=\".*\\.spec\\.e2e\\.ts$\"",
    "test:cov": "jest --coverage",
    "migration:create": "cross-env IGNORE_MIGRATIONS=false node create-migration.js",
    "migration:run": "cross-env IGNORE_MIGRATIONS=false ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d ./src/@database/data-source-only-for-migration.ts migration:run",
    "migration:revert": "cross-env IGNORE_MIGRATIONS=false ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d ./src/@database/data-source-only-for-migration.ts migration:revert",
    "migration:run:prod": "cross-env IGNORE_MIGRATIONS=false node ./node_modules/typeorm/cli.js -d ./dist/@database/data-source-only-for-migration.js migration:run",
    "migration:revert:prod": "cross-env IGNORE_MIGRATIONS=false node ./node_modules/typeorm/cli.js -d ./dist/@database/data-source-only-for-migration.js migration:revert"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/client-ses": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@bull-board/api": "^7.0.0",
    "@bull-board/express": "^7.0.0",
    "@bull-board/nestjs": "^7.0.0",
    "@casl/ability": "^6.8.1",
    "@keyv/redis": "^5.1.6",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/event-emitter": "^3.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/typeorm": "^11.0.0",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.6",
    "cache-manager": "^7.2.8",
    "ejs": "^3.1.10",
    "express-basic-auth": "^1.2.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "keyv": "^5.6.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^11.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.23.8",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@jest/globals": "^30.4.1",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@types/bcryptjs": "^3.0.0",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-helpers": "^2.0.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.0"
  }
}